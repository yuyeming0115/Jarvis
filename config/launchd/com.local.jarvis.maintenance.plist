<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.local.jarvis.maintenance</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/bash</string>
      <string>/Users/zoe/Jarvis/services/run-maintenance.sh</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
      <key>Hour</key>
      <integer>3</integer>
      <key>Minute</key>
      <integer>15</integer>
    </dict>

    <key>WorkingDirectory</key>
    <string>/Users/zoe/Jarvis</string>

    <key>StandardOutPath</key>
    <string>/Users/zoe/Jarvis/logs/maintenance.launchd.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/zoe/Jarvis/logs/maintenance.launchd.err.log</string>
  </dict>
</plist>
