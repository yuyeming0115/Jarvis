# Feishu App
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# V2.2: Interactive Cards
# 1. Copy this file content to your .env file at project root
# 2. Fill in FEISHU_APP_ID and FEISHU_APP_SECRET to enable card replies
# 3. In Feishu Open Platform, configure:
#    - Event Subscription: request URL = your public callback URL /api/feishu/event
#    - Card Request URL: same URL /api/feishu/event (same endpoint handles both)
#    - Bot permissions required: im:message, im:message:send_as_bot
