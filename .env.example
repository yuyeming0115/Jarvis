# Workbench
JARVIS_WORKBENCH_PORT=8080
JARVIS_SAFE_MODE=true
JARVIS_PUBLIC_ACCESS=false
# Set this to override auto-detection:
# JARVIS_ROOT=/path/to/Jarvis

# Feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# WeChat / Official Account / WeCom
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=
WECHAT_ENCODING_AES_KEY=

# TinyRouter (for AI classification V3.0+)
# OpenAI-compatible API endpoint (point to your TinyRouter instance)
# TINYROUTER_API_KEY is optional (only needed if TinyRouter requires auth)
# TINYROUTER_MODEL_MAP: alias=provider/model pairs (comma separated), e.g. "deepseek-chat=glm/deepseek-ai/deepseek-v4-flash"
TINYROUTER_BASE_URL=http://127.0.0.1:20129/v1
# TINYROUTER_API_KEY=
# TINYROUTER_MODEL_MAP=deepseek-chat=glm/deepseek-ai/deepseek-v4-flash,deepseek-reasoner=glm/deepseek-ai/deepseek-v4-pro
