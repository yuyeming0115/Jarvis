# Workbench
JARVIS_WORKBENCH_PORT=8080
JARVIS_SAFE_MODE=true
JARVIS_PUBLIC_ACCESS=false
# Set this to override auto-detection:
# JARVIS_ROOT=/path/to/Jarvis

# Feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# WeChat / Official Account / WeCom
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=
WECHAT_ENCODING_AES_KEY=

# TinyRouter
TINYROUTER_BASE_URL=http://127.0.0.1:20128/v1
